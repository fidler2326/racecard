<%= form_for(@card) do |f| %>
  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div class="form-group">
    <%= f.label :race_date %>
    <%= f.date_field :race_date, class: "form-control" %>
  </div>

  <div class="form-actions">
    <%= f.submit %>
  </div>
<% end %>