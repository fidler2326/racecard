<%= form_for([@card, @race]) do |f| %>
  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div class="form-group">
    <%= f.label :number %>
    <%= f.number_field :number %>
  </div>

  <div class="form-group">
    <%= f.label :time, "Time" %>
    <%= f.time_field :time, class: "form-control" %>
  </div>

  <div class="form-actions">
    <%= f.submit %>
  </div>
<% end %>
