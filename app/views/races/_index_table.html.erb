<h3><%= @card.name %></h3>

<% if @races.any? %>
  <table class="table">
    <thead>
    <tr>
      <th>Number</th>
      <th>Name</th>
      <th>Time</th>
      <th>Actions</th>
    </tr>
    </thead>

    <tbody>
    <% @races.each do |race| %>
      <tr>
        <td><%= race.number %></td>
        <td><%= race.name %></td>
        <td><%= race.time&.strftime("%H:%M") %></td>
        <td>
          <!-- TODO: view should navigate to the race show page, listing all the runners -->
          <!-- TODO: add runners relation -->
          <div class="actions">
            <%= button_to "View",
                          race_path(race),
                          method: :get,
                          class: "action-button" %>
            <%= button_to "Edit",
                          edit_race_path(race),
                          method: :get,
                          class: "action-button" %>
            <%= button_to "Delete",
                          race_path(race),
                          method: :delete,
                          form: { onsubmit: "return confirm('Are you sure you want to delete this race?')" },
                          class: "action-button" %>
          </div>      <!-- TODO: add a delete button -->
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
<% else %>
  <p>No races have been added yet.</p>
<% end %>